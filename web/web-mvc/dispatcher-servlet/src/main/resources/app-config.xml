<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd
                           http://www.springframework.org/schema/context
                           http://www.springframework.org/schema/context/spring-context.xsd
                           http://www.springframework.org/schema/mvc
                           http://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!-- Equivalent to @ComponentScan -->
    <context:component-scan base-package="com.dangminhphuc.dev.webmvc.dispatcher"/>

    <!-- Equivalent to @EnableWebMvc -->
    <mvc:annotation-driven/>

    <!-- Define DeclarativeXmlServletInitializerImpl bean -->
    <bean id="xmlServletInitializer" class="com.dangminhphuc.dev.webmvc.dispatcher.DeclarativeXmlServletInitializerImpl"/>

    <!-- Define EmbeddedJettyServer bean -->
    <bean id="embeddedJettyServer" class="com.dangminhphuc.dev.webmvc.dispatcher.EmbeddedJettyServer">
        <constructor-arg value="0"/> <!-- Port -->
        <constructor-arg ref="xmlServletInitializer"/>
    </bean>

</beans>
